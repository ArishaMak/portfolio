      </div>
    </div>
    <h3 class="about__name reveal" style="--reveal-delay: 0.2s">Arina N.<br />Makovchik</h3>
    <div class="about__content">
      <div class="about__image-box reveal" style="--reveal-delay: 0.3s">
        <img 
          src="/images/my-photo.PNG" 
          alt="Arina N. Makovchik" 
          class="about__image" 
          loading="lazy" 
          decoding="async"
          width="600" 
          height="600"
        />
      </div>
      <div class="about__text-wrapper">
        <div class="about__description">
          <span class="about__cta reveal" style="--reveal-delay: 0.4s">
            Cover letter
          </span>
          <hr class="about__divider" />
          <p class="reveal" style="--reveal-delay: 0.5s">
            I am a Frontend Developer dedicated to building smooth,
            modern, and user-friendly digital experiences. Currently a 3rd-year Software Engineering student
            at MRK/BSUIR and a graduate of the Yandex Practicum Frontend course (2025–2026),
            I combine technical precision with a strong eye for UI/UX.
            My approach is to take every project from a Figma concept to a fully deployed
            production-ready application.
          </p>
          <p class="reveal" style="--reveal-delay: 0.6s">
            My technical foundation is built on React, TypeScript, Node.js, and Express.js.
            I have hands-on experience implementing RESTful APIs, managing complex state,
            and working with both relational (SQL) and non-relational (MongoDB) databases.
            Having earned a High School Diploma in Fine Arts after seven years of formal training,
            I leverage a deep understanding of composition and aesthetics to create clean,
            minimalist, and truly human-centric interfaces.
          </p>
           
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initAboutReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.about .reveal').forEach(el => observer.observe(el));
  }
  initAboutReveal();
  document.addEventListener('astro:after-swap', initAboutReveal);

  function initScrollDepth() {
    const section = document.querySelector(".about");
    if (!section) return;

    function update() {
      // Проверяем ширину экрана. Если меньше 480 — сбрасываем стили и выходим
      if (window.innerWidth <= 480) {
        section.style.transform = '';
        return; 
      }

      const rect = section.getBoundingClientRect();
      const windowHeight = window.innerHeight;

      // Рассчитываем прогресс (от 0 до 1)
      const progress = Math.min(Math.max(1 - rect.top / windowHeight, 0), 1);

      const scale = 1 - progress * 0.15;
      const z = progress * -200;
      const rotateX = progress * 5;

      section.style.transform = `
        translateZ(${z}px)
        scale(${scale})
        rotateX(${rotateX}deg)
      `;

      requestAnimationFrame(update);
    }

    requestAnimationFrame(update);
  }

initScrollDepth();
document.addEventListener("astro:after-swap", initScrollDepth);

// загрузка фонового видео
  function initBackgroundVideo() {
    const video = document.getElementById('about-video');
    if (!video) return;

    const showVideo = () => {
      video.classList.add('loaded');
    };

    // Если видео уже достаточно загружено
    if (video.readyState >= 3) {
      showVideo();
    } else {
      // Ждём, пока видео можно будет воспроизвести
      video.addEventListener('canplay', showVideo, { once: true });
      video.addEventListener('loadeddata', showVideo, { once: true });
    }

    // На случай ошибки загрузки видео — всё равно убираем чёрный фон
    video.addEventListener('error', () => {
      video.classList.add('loaded');
    });
  }

  // Запускаем при загрузке страницы
  initBackgroundVideo();

  document.addEventListener('astro:after-swap', initBackgroundVideo);
</script>