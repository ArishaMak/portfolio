---
import '../assets/styles/sections/about.css';
---
<section id="about" class="section about">
  <h2 class="section__title">About Me</h2>

  <div class="about__grid">
    <div class="about__photo-block">
      <img
        src="/images/kobep.png"
        alt="Portrait of Arina Makovchik"
        class="about__photo"
        loading="lazy"
      />
      <a href="#cover-letter" class="about__cover-button">
        Cover letter
      </a>
    </div>

    <div class="about__text" id="cover-letter">
      <p>
        I am genuinely interested in joining Andersen’s JavaScript Trainee Program...
      </p>
      <p>
        I have completed the Full Stack Developer course at YandexPracticum...
      </p>
    </div>
  </div>
</section>
