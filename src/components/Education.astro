---
import '../assets/styles/sections/education.css';
---

<section id="education" class="section education">
  <h2 class="section__title">Education</h2>

  <div class="education__grid">
    <div class="education__item">
      <p class="education__period">2023–2027</p>
      <p class="education__place">
        BSUIR Branch Minsk Radioengineering College (MRC)
      </p>
      <p class="education__detail">
        Diploma of Secondary Vocational Education in Mobile Systems
      </p>
    </div>

    <div class="education__item">
      <p class="education__period">2025–2026</p>
      <p class="education__place">Yandex Practicum</p>
      <p class="education__detail">Fullstack Developer Program</p>
    </div>

    <div class="education__note">
      <p>
        I understand that this may not be directly relevant to this specific role,
        but I also hold a High School Diploma in fine arts, which I completed between 2014 and 2021.
      </p>
      <p>
        Seven years of training to master the art of drawing stars for my portfolio :)
      </p>
    </div>
  </div>
</section>