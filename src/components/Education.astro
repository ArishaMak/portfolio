</section>
<script>
  function initEducationReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.education .reveal').forEach(el => observer.observe(el));
  }

  initEducationReveal();
  document.addEventListener('astro:after-swap', initEducationReveal);

  function initEducationScroll() {
    const section = document.querySelector(".education");
    if (!section) return;

    function update() {
    if (window.innerWidth <= 480) {
      section.style.transform = 'none';
      requestAnimationFrame(update);
      return;
    }

    const rect = section.getBoundingClientRect();
    const windowHeight = window.innerHeight;
    const progress = Math.min(Math.max(1 - rect.top / windowHeight, 0), 1);

    const scale = 1 - progress * 0.15;
    const z = progress * -200;
    const rotateX = progress * 5;

    section.style.transform = `
      translateZ(${z}px)
      scale(${scale})
      rotateX(${rotateX}deg)
    `;

    requestAnimationFrame(update);
  }

    requestAnimationFrame(update);
  }

  initEducationScroll();
  document.addEventListener("astro:after-swap", initEducationScroll);
</script>