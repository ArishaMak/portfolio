---
import "../assets/styles/sections/education.css";
---

<section id="education" class="section education">
  {/* Задний фон */}
  <div class="education__bg-carpet">
    <img
      src="/images/ковер.avif"
      alt=""
      class="education__carpet-img"
      aria-hidden="true"
    />
    <div class="education__noise-overlay"></div>
    <div class="education__scanlines"></div>
  </div>

  <div class="education__grid">
    <div class="education__header">
      <div class="education__title-wrapper reveal" style="--reveal-delay: 0.1s">
        <span
          class="education__bracket education__bracket--left"
          aria-hidden="true"
        >
          <svg viewBox="0 0 100 229" fill="none"
            ><path
              d="M64.731 12.1557C66.2999 12.3285 66.8177 9.93267 67.0806 8.55646C67.9564 3.97105 66.6557 1.66632 62.3052 1.17328C51.8702 -0.00934006 41.1918 4.78078 42.049 17.8565C42.7028 27.8289 44.4429 37.2952 44.5483 47.4152C44.6909 61.1069 44.8699 75.4352 40.9292 88.6811C36.2733 104.331 18.9096 120.708 3.21506 118.979C0.420436 118.671 0.464301 114.26 2.26939 112.638C6.60234 108.742 13.3024 106.455 18.6405 105.347C25.2298 103.98 31.7305 106.085 35.8529 111.946C40.094 117.975 38.6513 126.594 37.6631 133.628C35.9127 146.089 34.1164 157.275 34.6303 169.968C35.1324 182.37 34.0586 201.094 41.9198 210.814C49.0453 219.623 57.5709 226.025 68.5894 226.973C81.3206 228.068 93.0138 210.128 98.428 199.259"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path></svg
          >
        </span>
        <h2 class="education__title">Education</h2>
        <span
          class="education__bracket education__bracket--right"
          aria-hidden="true"
        >
          <svg viewBox="0 0 100 229" fill="none"
            ><path
              d="M64.731 12.1557C66.2999 12.3285 66.8177 9.93267 67.0806 8.55646C67.9564 3.97105 66.6557 1.66632 62.3052 1.17328C51.8702 -0.00934006 41.1918 4.78078 42.049 17.8565C42.7028 27.8289 44.4429 37.2952 44.5483 47.4152C44.6909 61.1069 44.8699 75.4352 40.9292 88.6811C36.2733 104.331 18.9096 120.708 3.21506 118.979C0.420436 118.671 0.464301 114.26 2.26939 112.638C6.60234 108.742 13.3024 106.455 18.6405 105.347C25.2298 103.98 31.7305 106.085 35.8529 111.946C40.094 117.975 38.6513 126.594 37.6631 133.628C35.9127 146.089 34.1164 157.275 34.6303 169.968C35.1324 182.37 34.0586 201.094 41.9198 210.814C49.0453 219.623 57.5709 226.025 68.5894 226.973C81.3206 228.068 93.0138 210.128 98.428 199.259"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path></svg
          >
        </span>
      </div>

      <div class="education__years">
        <div class="education__year-item reveal" style="--reveal-delay: 0.2s">
          <strong>2023–2027</strong>
          <span>BSUIR · MRC Minsk</span>
        </div>
        <div class="education__year-item reveal" style="--reveal-delay: 0.3s">
          <strong>2025–2026</strong>
          <span>Yandex Practicum</span>
        </div>
        <div class="education__year-item reveal" style="--reveal-delay: 0.4s">
          <strong>Apr 2026 – now</strong>
          <span>Etacar Systems · BuzzyBooth</span>
        </div>
      </div>
    </div>

    <div class="education__main">
      <div class="education__motivation">
        <p class="reveal" style="--reveal-delay: 0.5s">
          My engineering foundation builds on rigorous academic deep-dives into
          Databases, complex algorithms, and OOP at MRC (BSUIR), amplified by
          958 hours of intensive frontend specialization at Yandex Practicum.
          This dual path bridges absolute structural discipline with modern
          production standards in React, TypeScript, and robust
          Node.js/PostgreSQL architecture.
        </p>
        <p class="reveal" style="--reveal-delay: 0.6s">
          Currently scaling real-world solutions within the US SaaS market at
          Etacar Systems, I deliver optimized code under senior mentorship,
          mastering high-load optimization and clean system design. I am fully
          prepared to relocate to Poland or Germany, looking to bring immediate
          architectural value and autonomous execution to a process-driven
          engineering team.
        </p>
      </div>

      <div class="education__carpet-card reveal" style="--reveal-delay: 0.7s">
        <div class="education__art-text">
          <p class="art-phrase">
            I combine clean code with attention to interface details.
          </p>
          <div class="education__motivation-sub">
            <p>
              // Seven years of fine arts — now I draw brackets instead of
              portraits :]
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initEducationReveal() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            if (!document.body.classList.contains("site-loaded")) return;
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -80px 0px" },
    );

    function startObserving() {
      document
        .querySelectorAll(".education .reveal")
        .forEach((el) => observer.observe(el));
    }

    if (document.body.classList.contains("site-loaded")) {
      startObserving();
    } else {
      const checkReady = setInterval(() => {
        if (document.body.classList.contains("site-loaded")) {
          clearInterval(checkReady);
          startObserving();
        }
      }, 100);
    }
  }

  initEducationReveal();
  document.addEventListener("astro:after-swap", initEducationReveal);

  let educationRafId: number;

  function initEducationScroll() {
    const section = document.querySelector(".education") as HTMLElement;
    if (!section) return;

    function update() {
      if (window.innerWidth <= 768) {
        section.style.transform = "";
        educationRafId = requestAnimationFrame(update);
        return;
      }

      const rect = section.getBoundingClientRect();
      const windowHeight = window.innerHeight;
      const progress = Math.min(
        Math.max(
          1 - (rect.top + rect.height / 2) / (windowHeight + rect.height / 2),
          0,
        ),
        1,
      );

      const scale = 1 - progress * 0.08;
      const z = progress * -120;
      const rotateX = (progress - 0.5) * 6;
      const yMove = (progress - 0.5) * 50;

      section.style.transform = `perspective(1000px) translate3d(0, ${yMove}px, ${z}px) scale(${scale}) rotateX(${rotateX}deg)`;
      educationRafId = requestAnimationFrame(update);
    }

    educationRafId = requestAnimationFrame(update);
  }

  document.addEventListener("astro:before-swap", () => {
    cancelAnimationFrame(educationRafId);
  });

  initEducationScroll();
  document.addEventListener("astro:after-swap", initEducationScroll);
</script>
