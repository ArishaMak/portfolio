---
import InfoCard from './InfoCard.astro';
import '../assets/styles/sections/hero.css';
---
<section class="section hero">
  <div class="hero__container page">
    
    <div class="hero__layout">
      <h1 class="hero__title">
        <span class="hero__title-shadow" aria-hidden="true">
          JavaScript<br />
          Trainee,<br />
          resume
        </span>
        <span class="hero__title-main">
          JavaScript<br />
          Trainee,<br />
          resume
        </span>
      </h1>

      <div class="hero__cards">
        <InfoCard
          title="About"
          content="BSUIR Branch MRC 2023–2027\nYandex Practicum Fullstack 2025–2026\nPortfolio Works 2025–2026"
        />
        <InfoCard
          title="Contact"
          content="makovchikarina@icloud.com\n+375 29 501-81-09\ntg: @ichbinrisha"
        />
        <InfoCard
          title="Information"
          content="github.com/ArishaMak"
        />
      </div>
    </div>

    <div class="hero__blob hero__blob--left-large"></div>
    <div class="hero__blob hero__blob--right-large">
      <div class="blob-layer--back"></div>
      <div class="blob-layer--front"></div>
    </div>
    <div class="hero__blob hero__blob--right-small"></div>
  </div>
</section>
<script>
  function initHeroAnimation() {
    const mainTitle = document.querySelector('.hero__title-main');
    const shadowTitle = document.querySelector('.hero__title-shadow');
    const heroTitle = document.querySelector('.hero__title');
    
    if (!mainTitle || !shadowTitle) return;

    // Очищаем контейнеры перед заполнением
    const textLines = ["JavaScript", "Trainee,", "resume"];

    const fillTitle = (container, isShadow) => {
      container.innerHTML = ''; 
      let globalCharIndex = 0; // Общий счетчик для ВСЕХ букв во всех строках

      textLines.forEach((lineText, lineIndex) => {
        const lineChars = lineText.split('');
        
        lineChars.forEach((char) => {
          const span = document.createElement('span');
          span.classList.add('letter');
          
          if (char === ' ') {
            span.innerHTML = '&nbsp;';
          } else {
            span.textContent = char;
          }

          // --- ТАЙМЕР ТУТ ---
          // 0.03 — это шаг (чем меньше, тем быстрее пробежит волна по буквам)
          const charDelay = (globalCharIndex * 0.03).toFixed(3);
          span.style.setProperty('--animation-delay', `${charDelay}s`);

          if (!isShadow) {
            span.addEventListener('mouseenter', () => {
              const allMain = mainTitle.querySelectorAll('.letter');
              const allShadow = shadowTitle.querySelectorAll('.letter');
              const idx = Array.from(allMain).indexOf(span);

              [span, allShadow[idx]].forEach(el => {
                if (el) {
                  el.classList.remove('jump-on-hover');
                  void el.offsetWidth;
                  el.classList.add('jump-on-hover');
                }
              });
            });
          }

          container.appendChild(span);
          globalCharIndex++; // Увеличиваем счетчик для следующей буквы
        });

        if (lineIndex < textLines.length - 1) {
          container.appendChild(document.createElement('br'));
        }
      });
    };

    fillTitle(mainTitle, false);
    fillTitle(shadowTitle, true);

    // Добавляем класс загрузки
    heroTitle.classList.add('is-loading');
    
    // --- ОБЩИЙ ТАЙМЕР КЛАССА ---
    // Увеличьте это число (например, до 2000), если букв много и они не успевают допрыгать
    setTimeout(() => {
      heroTitle.classList.remove('is-loading');
    }, 2000); 
  }

  document.addEventListener('DOMContentLoaded', initHeroAnimation);
</script>