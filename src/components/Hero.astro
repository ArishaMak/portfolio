---
import InfoCard from './InfoCard.astro';
import '../assets/styles/sections/hero.css';

const isMobile = Astro.clientWidth <= 480; // Проверяем ширину на сервере (Astro)

const textLines = isMobile 
  ? ["Junior", "Frontend &", "Full-Stack", "Developer"] // Мобильная версия
  : ["Junior", "Frontend & Full-Stack", "Developer"]; // Десктоп + планшет

let globalCharCounter = 0;
---

<section class="section hero">
  <div class="hero__container page">
    <div class="hero__layout">
      <h1 class="hero__title is-loading" aria-label="Junior Frontend & Full-Stack Developer">
        {['shadow', 'main'].map((type) => {
          globalCharCounter = 0;
          
          return (
            <span class={`hero__title-${type}`} aria-hidden={type === 'shadow'}>
              {textLines.map((line, lineIdx) => (
                <>
                  {line.split('').map((char) => {
                    const delay = (globalCharCounter * 0.03).toFixed(3);
                    const currentIndex = globalCharCounter;
                    globalCharCounter++;

                    return (
                      <span 
                        class="letter" 
                        style={`--animation-delay: ${delay}s`}
                        data-index={currentIndex}
                      >
                        {char === ' ' ? '\u00A0' : char}
                      </span>
                    );
                  })}
                  {/* Добавляем <br> между всеми строками на мобильной версии */}
                  {lineIdx < textLines.length - 1 && <br />}
                </>
              ))}
            </span>
          )
        })}
      </h1>
      <h2 class="sub">
        <span 
        class="typewriter-text" 
        data-text="Available for Summer 2026 Internship (July–September full-time)\n& Ready to relocate to Warsaw / Kraków\nOpen to part-time collaboration from October while writing my diploma project."
        ></span>
      </h2>
      <div class="hero__cards">
        <InfoCard
          title="About"
          content="BSUIR Branch MRC 2023–2027\nYandex Practicum Fullstack 2025–2026\nPortfolio Works 2025–2026"
        />
        <InfoCard
          title="Contact"
          content="makovchikarina@icloud.com\n+375 29 501-81-09\ntg: @ichbinrisha"
        />
        <InfoCard
          title="Information"
          content="github.com/ArishaMak"
        />
      </div>
    </div>

    <div class="hero__blob hero__blob--left-large"></div>
    <div class="hero__blob hero__blob--right-large">
      <div class="blob-layer--back"></div>
      <div class="blob-layer--front"></div>
    </div>
    <div class="hero__blob hero__blob--right-small"></div>
    <div class="hero__blob hero__blob--left-large-hero"></div>
  </div>
</section>

<script>
  function initHero() {
    const heroTitle = document.querySelector('.hero__title');
    const mainTitle = document.querySelector('.hero__title-main');
    const shadowTitle = document.querySelector('.hero__title-shadow');
    const typewriterElem = document.querySelector('.typewriter-text');
    const sidebarSwitch = document.querySelector('.sidebar-switch') as HTMLInputElement;

    if (!heroTitle || !mainTitle || !shadowTitle || !typewriterElem) return;

    let isStarted = false;

    // Основная функция запуска анимации
    function startSequence() {
      if (isStarted) return;
      isStarted = true;

      // 1. Появление букв h1 (управляется CSS через .is-loading)
      heroTitle.classList.remove('is-loading');

      // 2. Запуск печатной машинки h2
      const fullText = typewriterElem.getAttribute('data-text') || "";
      let charIndex = 0;
      typewriterElem.textContent = ""; // Очищаем перед стартом

      function type() {
        if (charIndex < fullText.length) {
          if (fullText.substr(charIndex, 2) === "\\n") {
            typewriterElem.innerHTML += "<br>";
            charIndex += 2;
          } else {
            typewriterElem.innerHTML += fullText.charAt(charIndex);
            charIndex++;
          }
          setTimeout(type, 35);
        }
      }
      
      // Небольшая задержка, чтобы h1 начал проявляться первым
      setTimeout(type, 500);
    }

    // Слушаем закрытие сайдбара
    if (sidebarSwitch) {
      sidebarSwitch.addEventListener('change', () => {
        if (!sidebarSwitch.checked) {
          // Запуск через 400мс после того, как шторка начала уезжать
          setTimeout(startSequence, 400);
        }
      });
    }

    // Резервный запуск (если пользователь не открыл меню в течение 2 сек)
    setTimeout(startSequence, 2000);

    // Ховер эффект для букв (делегирование)
    mainTitle.addEventListener('mouseover', (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains('letter')) {
        const idx = target.getAttribute('data-index');
        const shadowLetter = shadowTitle.querySelector(`[data-index="${idx}"]`);

        [target, shadowLetter].forEach(el => {
          if (el) {
            el.classList.remove('jump-on-hover');
            void (el as HTMLElement).offsetWidth; 
            el.classList.add('jump-on-hover');
          }
        });
      }
    });
  }

  // Запуск при загрузке
  document.addEventListener('DOMContentLoaded', initHero);
</script>