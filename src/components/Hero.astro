---
import '../assets/styles/sections/hero.css';

const line1 = "JUNIOR";
const line2chars = [
  { text: "FULL", style: "outlined" },
  { text: "STACK", style: "carpet" },
];
const line3 = "DEVELOPER";

let counter1 = 0;
let counter2 = 0;
let counter3 = 0;
---

<section class="section hero">
  <div class="hero__container page">
    <div class="hero__layout">

      <div class="hero__topbar">
        <span class="hero__name-label">Arina N. Makovchik</span>
        <div class="hero__status">
          <span class="hero__status-dot"></span>
          MINSK, BELARUS · OPEN TO OFFICE RELOCATION
        </div>
      </div>

      <div class="hero__rule"></div>

      <div class="hero__tag">
        <span>Node.js</span>
        <span class="hero__tag-sep">·</span>
        <span>MongoDB</span>
        <span class="hero__tag-sep">·</span>
        <span>React</span>
        <span class="hero__tag-sep">·</span>
        <span>Angular</span>
        <span class="hero__tag-sep">·</span>
        <span>TypeScript</span>
      </div>

      <h1 class="hero__title" aria-label="Junior Fullstack Developer">

        <span class="hero__title-line hero__title-line--plain is-loading" id="line1">
          {["shadow","main"].map((type) => {
            counter1 = 0;
            return (
              <span class={`hero__title-${type}`} aria-hidden={type === "shadow"}>
                {line1.split("").map((char) => {
                  const delay = (counter1 * 0.025).toFixed(3);
                  const idx = counter1++;
                  return (
                    <span class="letter" style={`--animation-delay:${delay}s`} data-index={`1-${idx}`}>
                      {char}
                    </span>
                  );
                })}
              </span>
            );
          })}
        </span>

        <span class="hero__title-line hero__title-line--mixed">
          <span class="hero__word-outlined" aria-hidden="false">
            {"FULL".split("").map((char, i) => (
              <span
                class="letter letter--outlined"
                style={`--animation-delay:${(i * 0.025 + 0.2).toFixed(3)}s`}
                data-index={`2-${i}`}
              >{char}</span>
            ))}
          </span>
          <span class="hero__word-carpet" aria-hidden="false">
            {"STACK".split("").map((char, i) => (
              <span
                class="letter letter--carpet"
                style={`--animation-delay:${(i * 0.025 + 0.35).toFixed(3)}s`}
                data-index={`2c-${i}`}
              >{char}</span>
            ))}
          </span>
        </span>

        <span class="hero__title-line hero__title-line--plain is-loading" id="line3">
          {["shadow","main"].map((type) => {
            counter3 = 0;
            return (
              <span class={`hero__title-${type}`} aria-hidden={type === "shadow"}>
                {"DEVELOPER".split("").map((char) => {
                  const delay = (counter3 * 0.025 + 0.45).toFixed(3);
                  const idx = counter3++;
                  return (
                    <span class="letter" style={`--animation-delay:${delay}s`} data-index={`3-${idx}`}>
                      {char}
                    </span>
                  );
                })}
              </span>
            );
          })}
        </span>

      </h1>

      <div class="hero__bottom">
        <div class="hero__bottom-left">
          <p class="hero__exp-line">
            Commercial experience&nbsp;·&nbsp;<span class="hero__exp-accent">EtaCar Systems (BuzzyBooth, US)</span>
          </p>
          <p class="hero__exp-line">
            Yandex Practicum&nbsp;·&nbsp;<span class="hero__exp-accent">958h</span>&nbsp;·&nbsp;MRC BSUIR
          </p>
          <p class="hero__exp-line">
            Open to relocation&nbsp;·&nbsp;<span class="hero__exp-accent">Poland&nbsp;·&nbsp;Germany</span>
          </p>
        </div>
        <div class="hero__reloc">
          <span class="hero__reloc-label">CURRENTLY IN MINSK</span>
          <div class="hero__reloc-cities">
            <span>Gybrid</span>
            <span class="hero__reloc-sep">/</span>
            <span>Office</span>
          </div>
        </div>
      </div>

    </div>

    <!-- Scroll indicator -->
    <div class="hero__scroll-indicator" aria-hidden="true">
      <span>scroll</span>
      <div class="hero__scroll-line"></div>
    </div>

  </div>
</section>

<script>
  function initHero() {
    const line1 = document.getElementById('line1');
    const line3 = document.getElementById('line3');
    const mainTitles = document.querySelectorAll('.hero__title-main');
    const shadowTitles = document.querySelectorAll('.hero__title-shadow');

    let isStarted = false;
    const sidebarSwitch = document.querySelector('.sidebar-switch') as HTMLInputElement;

    function startSequence() {
      if (isStarted) return;
      isStarted = true;
      line1?.classList.remove('is-loading');
      line3?.classList.remove('is-loading');
    }

    if (sidebarSwitch) {
      sidebarSwitch.addEventListener('change', () => {
        if (!sidebarSwitch.checked) setTimeout(startSequence, 400);
      });
    }
    setTimeout(startSequence, 800);

    // jump-on-hover для всех букв
    document.querySelector('.hero__title')?.addEventListener('mouseover', (e) => {
      const target = e.target as HTMLElement;
      if (!target.classList.contains('letter')) return;
      const idx = target.getAttribute('data-index');

      // находим пару shadow/main по data-index
      document.querySelectorAll(`.letter[data-index="${idx}"]`).forEach(el => {
        el.classList.remove('jump-on-hover');
        void (el as HTMLElement).offsetWidth;
        el.classList.add('jump-on-hover');
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initHero);
  document.addEventListener('astro:after-swap', initHero);
</script>