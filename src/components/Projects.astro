          </svg>
        </span>
      </div>
    </div>
 
    <div class="projects__grid">
      {allProjects.map((project, index) => (
        <article class="project-card reveal" style={{ "--reveal-delay": `${index * 0.08}s` }}>
          <div class="project-card__content">
            <div class="project-card__title-row">
              <h3 class="project-card__title">{project.title}</h3>
              {project.badge && (
                <span class="project-card__badge">
                  {project.badge}
                </span>
              )}
            </div>
            <p class="project-card__date">{project.date}</p>
 
            <div class="project-card__description-wrapper">
              <ul class="project-card__list">
                {project.description.map((item) => (
                  <li class="project-card__item" set:html={processText(item)} />
                ))}
              </ul>
            </div>
            <button class="read-more-btn">read more</button>
          </div>
 
          <div class="project-card__footer">
            {project.link ? (
              <a href={project.link} target="_blank" rel="noopener noreferrer" class="project-button">
                <span>VIEW ON GITHUB</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="7" y1="17" x2="17" y2="7"></line>
                  <polyline points="7 7 17 7 17 17"></polyline>
