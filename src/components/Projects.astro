    </div>
    
    <div class="projects__bottom-rule"></div>
    <div class="projects__bottom-row">
      <span class="projects__bottom-note">
        Click "read more" to expand large production specifications
      </span>
      <span class="projects__bottom-tag">Total codebases built</span>
    </div>

  </div>
</section>
 
<script>
  function initProjectsLogic() {
    // 1. Инициализация Reveal-анимации
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.05 });
 
    document.querySelectorAll('.projects .reveal').forEach(el => revealObserver.observe(el));
 
    // 2. Логика для раскрытия карточек (Read More)
    const cards = document.querySelectorAll('.project-card');
    
    cards.forEach((card) => {
      const wrapper = card.querySelector('.project-card__description-wrapper') as HTMLElement;
      const btn = card.querySelector('.read-more-btn') as HTMLElement;
      
      if (!wrapper || !btn) return;

      // Используем ResizeObserver вместо setTimeout для точного расчета высоты на мобильных
      const resizeObserver = new ResizeObserver(() => {
        if (card.classList.contains('is-expanded')) {
          btn.style.display = 'block';
          return;
        }
        
        // Сравниваем реальную высоту контента с ограничением по CSS
        const isOverflowing = wrapper.scrollHeight > wrapper.clientHeight;
        btn.style.display = isOverflowing ? 'block' : 'none';
      });

      // Начинаем следить за оберткой текста
      resizeObserver.observe(wrapper);
   
      // Обработчик клика
      btn.onclick = (e) => {
        e.preventDefault();
        const isExpanded = card.classList.toggle('is-expanded');
        btn.textContent = isExpanded ? 'show less' : 'read more';
      };
    });
  }
 
  // Запуск при первой загрузке и при смене страниц в Astro (View Transitions)
  initProjectsLogic();
  document.addEventListener('astro:after-swap', initProjectsLogic);
</script>