---
import '../assets/styles/sections/sidebar.css';

const pageNav = [
  { href: '#about', label: 'About' },
  { href: '#education', label: 'Education' },
  { href: '#skills', label: 'Skills' },
  { href: '#projects', label: 'Projects' },
  { href: '#additional-experience', label: 'Experience' },
  { href: '#contact', label: 'Contact' },
];

const socialLinks = [
  { href: "https://www.linkedin.com/in/arina-makovchik-910504365/", label: "LinkedIn" },
  { href: "https://github.com/ArishaMak", label: "GitHub" },
  { href: "https://www.instagram.com/ichbinrisha/", label: "Instagram" },
  { href: "https://t.me/@ichbinrisha", label: "Telegram" }
];
---

<input type="checkbox" id="sidebar-toggle" class="sidebar-switch" hidden />

<label for="sidebar-toggle" class="hamburger-menu" aria-label="Toggle Menu">
  <div class="burger-lines">
    <span class="line top"></span>
    <span class="line bottom"></span>
  </div>
</label>

<label for="sidebar-toggle" class="sidebar-backdrop"></label>

<aside class="sidebar-container">
  <div class="sidebar-inner">
    <nav class="sidebar-navigation">
      <!-- Якоря только на мобильных -->
      <ul class="nav-menu nav-page">
        {pageNav.map(link => (
          <li>
            <a href={link.href} class="nav-item"> {link.label} </a>
          </li>
        ))}
      </ul>

      <hr class="sidebar-divider" />

      <!-- Соцсети на всех экранах -->
      <ul class="nav-menu nav-social">
        {socialLinks.map(link => (
          <li>
            <a href={link.href} target="_blank" rel="noopener noreferrer" class="nav-item">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="sidebar-bottom">
      <div class="theme-section">
        <span class="theme-status">Dark Mode</span>
        <button id="theme-switcher" class="theme-toggle-node" aria-label="Switch Theme">
          <div class="track"><div class="thumb"></div></div>
        </button>
      </div>
    </div>
  </div>
</aside>

<script>
  const links = document.querySelectorAll('.nav-item');
  const toggle = document.getElementById('sidebar-toggle');

  links.forEach(link => {
    link.addEventListener('click', () => {
      if (toggle) toggle.checked = false;
    });
  });

  document.getElementById('theme-switcher')?.addEventListener('click', () => {
    const html = document.documentElement;
    const current = html.getAttribute('data-theme');
    const target = current === 'dark' ? 'light' : 'dark';
    document.dispatchEvent(new CustomEvent('theme-change', { detail: { theme: target } }));
  });
</script>