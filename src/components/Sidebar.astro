---
import '../assets/styles/sections/sidebar.css';

const navLinks = [
  { href: "#about", label: "About" },
  { href: "#education", label: "Education" },
  { href: "#skills", label: "Skills" },
  { href: "#projects", label: "Projects" },
  { href: "#contact", label: "Contact" }
];

const socialLinks = [
  { href: "https://github.com/ArinaMakovchik", label: "GitHub" },
  { href: "#", label: "LinkedIn" }
];
---

<input type="checkbox" id="sidebar-toggle" class="sidebar-switch" hidden />

<label for="sidebar-toggle" class="hamburger-menu" aria-label="Toggle Menu">
  <div class="burger-lines">
    <span class="line top"></span>
    <span class="line bottom"></span>
  </div>
</label>

<label for="sidebar-toggle" class="sidebar-backdrop"></label>

<aside class="sidebar-container">
  <div class="sidebar-inner">
    <nav class="sidebar-navigation">
      <ul class="nav-menu">
        {navLinks.map(link => (
          <li>
            <a href={link.href} class="nav-item">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="sidebar-bottom">
      <div class="theme-section">
        <span class="theme-status">Dark Mode</span>
        <button id="theme-switcher" class="theme-toggle-node">
          <div class="track">
            <div class="thumb"></div>
          </div>
        </button>
      </div>

      <div class="social-mini">
        {socialLinks.map(social => (
          <a href={social.href} class="social-link">{social.label}</a>
        ))}
      </div>
    </div>
  </div>
</aside>

<script>
  const btn = document.getElementById('theme-switcher');
  
  btn?.addEventListener('click', () => {
    const html = document.documentElement;
    const current = html.getAttribute('data-theme');
    const target = current === 'dark' ? 'light' : 'dark';
    
    document.dispatchEvent(new CustomEvent('theme-change', { 
      detail: { theme: target } 
    }));
  });

  const links = document.querySelectorAll('.nav-item');
  const toggle = document.getElementById('sidebar-toggle') as HTMLInputElement;

  links.forEach(l => l.addEventListener('click', () => {
    if (toggle) toggle.checked = false;
  }));
</script>