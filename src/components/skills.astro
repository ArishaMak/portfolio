          <div class="wordsearch-grid">
            {wordSearchGrid.map((row, rowIndex) => (
              <div class="wordsearch-row" key={rowIndex}>
                {row.map((letter, colIndex) => (
                  <div
                    class="wordsearch-cell"
                    key={`${rowIndex}-${colIndex}`}
                    data-letter={letter.trim() !== '' ? letter : ''}
                    onClick={() => {
                      const cell = document.querySelector(`[data-letter="${letter.trim()}"]`);
                      if (cell) cell.classList.toggle('highlighted');
                    }}
                  >
                    {letter}
                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>
        <div class="memes-sidebar">
          <div class="memes-grid">
            {Array.from({ length: 9 }).map((_, i) => (
              <div 
              class="meme-frame" 
              id={`meme-${i}`} 
              data-active="false"
              >
              <img 
              src="" 
              alt="meme" 
              loading="lazy"
              />
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="skills__grid">
      {skillCategories.map((category, index) => (
        <div
          class="skill-card reveal"
          style={`--reveal-delay: ${index * 0.12}s`}
        >
        <video muted loop playsinline preload="none">
          <source src="/images/video-for-card.mp4" type="video/mp4">
        </video>
          <div class="skill-card__badge">
            <span>{category.title}</span>
          </div>
          <ul class="skill-card__list">
            {category.skills.map((skill) => (
              <li class="skill-card__item">{skill}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function initReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  }

  initReveal();
  document.addEventListener('astro:after-swap', initReveal);

  const memesFrames = document.querySelectorAll('.meme-frame');

  const memeImages = Array.from({ length: 65 }, (_, i) => {
    const num = String(i + 1).padStart(2, '0');
    return `/images/memes/mem${num}.jpg`;
  });

  function getRandomMeme() {
    return memeImages[Math.floor(Math.random() * memeImages.length)];
  }

  function activateRandomMemes() {
    // Сброс всех фреймов
    memesFrames.forEach(frame => {
      frame.dataset.active = "false";
      const img = frame.querySelector('img');
      if (img) {
        img.src = "";
        img.classList.remove('error');
      }
    });

    // Выбираем 4–5 случайных
    const count = Math.floor(Math.random() * 4) + 2;
    const shuffled = [...memesFrames].sort(() => Math.random() - 0.5);
    const selected = shuffled.slice(0, count);

    selected.forEach(frame => {
      const img = frame.querySelector('img');
      if (!img) return;

      frame.dataset.active = "true";

      const url = getRandomMeme();
      const preload = new Image();

      preload.onload = () => {
        img.src = url;
        img.classList.remove('error');
      };

      preload.onerror = () => {
        img.src = "";
        img.classList.add('error');
      };

      preload.src = url;
    });
  }

  // Запуск
  activateRandomMemes();
  setInterval(activateRandomMemes, 1500);

  document.querySelectorAll('.skill-card').forEach(card => {
  const video = card.querySelector('video');
  
  card.addEventListener('mouseenter', () => {
    if (video) {
      video.play().catch(() => {});
    }
  });
  
  card.addEventListener('mouseleave', () => {
    if (video) {
      video.pause();
    }
  });
  });

  function initSkillsParallax() {
    const skillsSection = document.querySelector('.section.skills');
    if (!skillsSection) return;

    window.addEventListener('scroll', () => {
        const rect = skillsSection.getBoundingClientRect();
        const windowHeight = window.innerHeight;

        // Проверяем, находится ли секция в области видимости
        if (rect.top < windowHeight && rect.bottom > 0) {
            // Вычисляем прогресс прохождения секции через вьюпорт (от 0 до 1)
            // 0 - секция только появилась снизу, 1 - секция уходит вверх
            const scrollProgress = (windowHeight - rect.top) / (windowHeight + rect.height);
            
            // Параметры эффекта:
            // Начинаем с 1.0 (оригинальный размер) и уменьшаем до 0.85
            const scale = 1 - (scrollProgress * 0.15); 
            
            // translateZ создаёт эффект физического отдаления в 3D пространстве
            const translateZ = scrollProgress * -100; 

            // Опционально: можно добавить небольшое затемнение при отдалении
            const opacity = 1 - (scrollProgress * 0.5);

            skillsSection.style.transform = `scale(${scale}) translateZ(${translateZ}px)`;
            // skillsSection.style.opacity = opacity; // Раскомментируйте, если нужно затухание
        }
    });
}

// Запуск при загрузке
initSkillsParallax();
// Запуск после смены страниц в Astro
document.addEventListener('astro:after-swap', initSkillsParallax);
</script>