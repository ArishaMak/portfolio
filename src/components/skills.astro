<section id="skills" class="section skills">
  <div class="skills__container">
    
    <div class="skills__header reveal">
      <div class="skills__title-wrapper">
         <h2 class="skills__title">Skills</h2>
         <svg class="skills__underline" width="248" height="144" viewBox="0 0 248 144" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M101.191 19.9936C102.537 9.65427 133.627 13.4701 141.343 14.2654C167.208 16.9314 187.665 24.711 209.222 35.3694C226.007 43.6685 243.729
