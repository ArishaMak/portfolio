---
import '../assets/styles/sections/skills.css';

const skillCategories = [
  {
    title: "Frontend",
    skills: ["HTML5, CSS3", "Responsive Design (Flexbox, Grid)", "JavaScript (ES6+)", "DOM Manipulation", "React", "React Router", "Redux (basic knowledge)", "TypeScript (basic knowledge)", "REST API integration", "Vite"]
  },
  {
    title: "Backend",
    skills: ["Node.js (basic level)", "Express.js", "RESTful API development", "Asynchronous programming", "Modular architecture principles", "OOP fundamentals"]
  },
  {
    title: "Databases",
    skills: ["SQL (DML, DDL)", "Database Design (Normalization, ER-modeling)", "MS SQL Server", "Data Integrity & Constraints", "Database Administration & Security"]
  },
  {
    title: "Testing",
    skills: ["Jest (basic)", "Cypress (basic)", "Debugging tools", "Application optimization basics"]
  },
  {
    title: "Languages",
    skills: ["English — B1+", "Deutsch — A1+", "Russian, Belarusian — native"]
  }
];
---

<section id="skills" class="section skills">
  <div class="skills__container">
    
    <div class="skills__header reveal">
      <div class="skills__title-wrapper">
         <h2 class="skills__title">Skills</h2>
         <svg class="skills__underline" width="248" height="144" viewBox="0 0 248 144" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M101.191 19.9936C102.537 9.65427 133.627 13.4701 141.343 14.2654C167.208 16.9314 187.665 24.711 209.222 35.3694C226.007 43.6685 243.729 59.5762 246.431 75.2661C250.212 97.2151 234.783 111.885 211.053 122.65C179.568 136.932 144.655 143 108.254 143C76.7356 143 43.4071 138.151 19.5797 121.343C-3.52079 105.048 -4.60965 82.4802 13.6943 63.2067C29.6912 46.3623 50.8072 33.012 74.6413 23.109C106.49 9.87591 144.86 5.86802 180.056 1" stroke="#0038FF" stroke-width="2" stroke-linecap="round"/>
         </svg>
      </div>
    </div>

    <div class="skills__grid">
      {skillCategories.map((category, index) => (
        /* на сервере вычисляем задержку для каждой карточки */
        <div 
          class="skill-card reveal" 
          style={`--reveal-delay: ${index * 0.12}s`}
        >
          <div class="skill-card__badge">
            <span>{category.title}</span>
          </div>
          <ul class="skill-card__list">
            {category.skills.map((skill) => (
              <li class="skill-card__item">{skill}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="skills__decorations" aria-hidden="true">
        <div class="skills__star skills__star--1 reveal" style="--reveal-delay: 0.5s">
          <img src="/images/skills__star--1.svg" alt="" width="116" height="87" loading="lazy" />
        </div>
        <div class="skills__star skills__star--2 reveal" style="--reveal-delay: 0.7s">
          <img src="/images/skills__star--2.svg" alt="" width="116" height="87" loading="lazy" />
        </div>
    </div>
  </div>
</section>

<script>
  /* скрипт выполнится на клиенте сразу после загрузки */
  function initReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  }

  // пуск
  initReveal();
  
  document.addEventListener('astro:after-swap', initReveal);
</script>