            stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
         </svg>
      </div>
    </div>

    <!-- Word Search блок -->
    <div class="wordsearch-wrapper reveal" style="--reveal-delay: 0.3s;">
      <div class="wordsearch-layout">
        <!-- Левый блок: слова -->
        <div class="wordsearch-words-left">
          <ul class="wordsearch-col">
            {skillWords.slice(0, Math.ceil(skillWords.length / 2)).map(word => {
              const overlay = pencilOverlays[word];
              return (
                <li 
                  key={word} 
                  class={`skill-word ${overlay ? `skill-word--${word.toLowerCase()}` : ''}`}
                >
                  {word}
                  {overlay && (
                    <svg
                      class={`pencil-stroke ${overlay.className}`}
                      width={overlay.width}
                      height={overlay.height}
                      viewBox={overlay.viewBox}
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                      style={overlay.style}
                    >
                      <path 
                        d={overlay.path} 
                        stroke="var(--pr-brackets)" 
                        stroke-width="0.5" 
                        stroke-linecap="round" 
                        opacity="0.85"
                      />
                    </svg>
                  )}
                </li>
              );
            })}
          </ul>

          <ul class="wordsearch-col">
            {skillWords.slice(Math.ceil(skillWords.length / 2)).map(word => {
              const overlay = pencilOverlays[word];
              return (
                <li 
                  key={word} 
                  class={`skill-word ${overlay ? `skill-word--${word.toLowerCase()}` : ''}`}
                >
                  {word}
                  {overlay && (
                    <svg
                      class={`pencil-stroke ${overlay.className}`}
                      width={overlay.width}
                      height={overlay.height}
                      viewBox={overlay.viewBox}
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                      style={overlay.style}
                    >
                      <path d={overlay.path} stroke="var(--pr-brackets)" stroke-width="0.5" stroke-linecap="round" opacity="0.85"/>
                    </svg>
                  )}
                </li>
              );
            })}
          </ul>
