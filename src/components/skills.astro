---
import '../assets/styles/sections/skills.css';
---

<section id="skills" class="section skills">
  <h2 class="section__title">Skills</h2>

  <div class="skills__categories">
    <div class="skills__category">
      <h3 class="skills__category-title">Frontend</h3>
      <ul class="skills__list">
        <li>HTML5, CSS3</li>
        <li>Responsive Design (Flexbox, Grid)</li>
        <li>JavaScript (ES6+)</li>
        <li>DOM Manipulation</li>
        <li>React, React Router</li>
        <li>Redux (basic)</li>
        <li>TypeScript (basic knowledge)</li>
        <li>REST API integration</li>
        <li>Vite</li>
      </ul>
    </div>

    <div class="skills__category">
      <h3 class="skills__category-title">Backend</h3>
      <ul class="skills__list">
        <li>Node.js (basic level)</li>
        <li>Express.js</li>
        <li>RESTful API development</li>
        <li>Asynchronous programming</li>
        <li>Modular architecture principles</li>
        <li>OOP fundamentals</li>
      </ul>
    </div>

    <div class="skills__category">
      <h3 class="skills__category-title">Databases</h3>
      <ul class="skills__list">
        <li>SQL (DML, DDL)</li>
        <li>Database Design (Normalization, ER‑modeling)</li>
        <li>MS SQL Server</li>
        <li>Data integrity &amp; Constraints</li>
        <li>Database Administration &amp; Security</li>
      </ul>
    </div>

    <div class="skills__category">
      <h3 class="skills__category-title">Testing</h3>
      <ul class="skills__list">
        <li>Jest (basic)</li>
        <li>Cypress (basic)</li>
        <li>Debugging tools</li>
        <li>Application optimization basics</li>
      </ul>
    </div>

    <div class="skills__category skills__category--languages">
      <h3 class="skills__category-title">Languages</h3>
      <ul class="skills__list">
        <li>English – B1+</li>
        <li>Russian – native</li>
        <li>Belarusian – native</li>
      </ul>
    </div>
  </div>
</section>