---
import '../assets/styles/sections/skills.css';

const skillCategories = [
  {
    title: "Frontend",
    skills: ["HTML5, CSS3", "Responsive Design (Flexbox, Grid)", "JavaScript (ES6+)", "DOM Manipulation", "React", "React Router", "Redux (basic knowledge)", "TypeScript (basic knowledge)", "REST API integration", "Vite"]
  },
  {
    title: "Backend",
    skills: ["Node.js (basic level)", "Express.js", "RESTful API development", "Asynchronous programming", "Modular architecture principles", "OOP fundamentals"]
  },
  {
    title: "Databases",
    skills: ["SQL (DML, DDL)", "Database Design (Normalization, ER-modeling)", "MS SQL Server", "Data Integrity & Constraints", "Database Administration & Security"]
  },
  {
    title: "Testing",
    skills: ["Jest (basic)", "Cypress (basic)", "Debugging tools", "Application optimization basics"]
  },
  {
    title: "Languages",
    skills: ["English — B1+", "Deutsch — A1+", "Russian, Belarusian — native"]
  }
];
---

<section id="skills" class="section skills">
  <div class="skills__container">
    
    <div class="skills__header reveal">
      <div class="skills__title-wrapper">
         <h2 class="skills__title">Skills</h2>
         <svg class="skills__underline" width="248" height="144" viewBox="0 0 248 144" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M101.191 19.9936C102.537 9.65427 133.627 13.4701 141.343 14.2654C167.208 16.9314 187.665 24.711 209.222 35.3694C226.007 43.6685 243.729 59.5762 246.431 75.2661C250.212 97.2151 234.783 111.885 211.053 122.65C179.568 136.932 144.655 143 108.254 143C76.7356 143 43.4071 138.151 19.5797 121.343C-3.52079 105.048 -4.60965 82.4802 13.6943 63.2067C29.6912 46.3623 50.8072 33.012 74.6413 23.109C106.49 9.87591 144.86 5.86802 180.056 1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
         </svg>
      </div>
    </div>

    <div class="skills__grid">
      {skillCategories.map((category, index) => (
        <div 
          class="skill-card reveal" 
          style={`--reveal-delay: ${index * 0.12}s`}
        >
          <div class="skill-card__badge">
            <span>{category.title}</span>
          </div>
          <ul class="skill-card__list">
            {category.skills.map((skill) => (
              <li class="skill-card__item">{skill}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="skills__decorations" aria-hidden="true">
        <div class="skills__star skills__star--1 reveal" style="--reveal-delay: 0.5s; color: var(--color-accent)">
          <svg width="116" height="87" viewBox="0 0 116 87" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12.163 82.8877C15.1962 74.4542 18.5113 69.8815 24.6364 64.2983C31.7659 57.7995 38.2682 50.5345 45.5173 44.2059C59.1426 32.3107 69.8227 16.735 84.0057 5.72194C85.4177 4.62551 87.037 3.66096 88.1061 2.08317C88.8767 0.945883 87.428 0.674277 87.2446 1.41078C85.7674 7.34558 85.6157 14.691 85.0394 20.7912C83.2868 39.3436 82.8686 57.7671 82.8686 76.4012C82.8686 78.8101 84.4117 87.6301 80.6978 85.7354C74.7985 82.7258 69.9347 73.7367 65.5368 68.6886C53.7903 55.2052 42.8292 39.936 28.0132 30.6792C22.4784 27.2212 16.8525 24.786 11.6806 20.5539C8.35059 17.8291 5.44022 14.7102 2.23936 11.8525C-2.64459 7.49217 8.34944 10.5238 10.3023 10.9823C24.0885 14.2192 37.3933 19.3221 50.9615 23.4807C67.0387 28.4084 83.6481 28.0543 100.097 29.3344C104.759 29.6972 118.669 29.3109 114.087 30.3628C106.956 31.9998 101.395 36.4318 94.9975 40.1716C79.9481 48.9689 63.8111 53.3189 47.8604 59.3939C38.3841 63.003 28.8609 66.7663 19.2611 69.9147C13.7323 71.7279 8.89274 73.5246 4.10004 77.1922" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>

        <div class="skills__star skills__star--2 reveal" style="--reveal-delay: 0.6s; color: var(--color-accent)">
          <svg width="127" height="85" viewBox="0 0 127 85" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0.999772 51.7018C16.8226 37.2375 34.854 23.4345 52.9808 11.3891C56.9135 8.7758 60.8078 5.23811 65.2413 3.32714C67.3825 2.40422 69.7823 2.11636 71.8876 1.21882C74.5424 0.0869945 73.6702 3.62896 73.8398 5.44756C74.8921 16.731 71.5185 28.4989 70.5816 39.6408C69.6282 50.98 69.6307 61.9707 72.0831 73.2705C72.8283 76.7042 75.8975 86.337 76.7003 82.978C77.0635 81.4582 73.0505 75.3514 72.1254 74.0003C66.2829 65.4676 60.1903 56.8743 54.0863 48.49C49.9176 42.764 46.0222 36.84 41.3658 31.4152C37.9097 27.3889 33.8494 23.885 30.3967 19.8626C27.4114 16.3847 24.2996 13.0798 21.1466 9.73488C19.8064 8.31308 17.6589 7.0054 16.6226 5.38219C16.4653 5.13575 29.884 8.43831 31.4565 8.92743C47.8008 14.0113 63.4961 21.2129 79.763 26.6228C92.6603 30.9122 105.583 34.2986 118.798 37.4568C121.16 38.0215 123.297 38.4985 125.432 39.6313C126.635 40.2696 121.476 40.9506 120.67 41.1105C107.787 43.6676 94.2058 44.4624 81.0667 45.8108C63.9702 47.5653 46.6537 48.886 29.4369 49.7306C22.5256 50.0697 15.2396 49.6056 8.43297 50.534" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>

        <div class="skills__star skills__star--3 reveal" style="--reveal-delay: 0.7s; color: var(--color-accent)">
          <svg width="97" height="70" viewBox="0 0 97 70" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9.04977 56.7689C7.94158 55.1885 9.49961 54.4797 10.4808 53.5943C13.9148 50.4955 16.8016 46.9425 19.7828 43.1634C24.1265 37.6572 28.6525 32.3029 32.7817 26.5345C36.0562 21.9602 38.6802 16.8573 42.3221 12.7023C43.1496 11.7583 50.2661 3.19563 48.6427 1.13772C47.4584 -0.363522 47.7764 10.8938 47.8079 11.3418C49.0192 28.5726 50.8134 47.7176 55.7384 63.9495C56.801 67.4515 59.2942 71.0108 55.321 67.6532C50.1129 63.2519 46.1591 57.1501 41.6662 51.7046C36.553 45.5073 33.2304 37.3164 27.5344 31.9011C23.1735 27.7552 18.3529 24.97 13.5815 21.7348C12.9014 21.2737 2.27472 14.079 3.44474 13.2314C6.38701 11.1002 10.4722 13.3232 13.4026 14.2519C25.1457 17.9733 36.5894 23.848 48.4638 26.7613C62.493 30.2033 76.6559 25.3553 90.74 27.177C93.8834 27.5836 98.7227 28.3025 94.0791 31.5988C87.8401 36.0277 78.9393 36.8129 72.0466 38.4015C56.7076 41.9368 41.8475 47.7214 26.5207 51.3267C20.2455 52.8028 13.9268 54.4006 7.52925 54.6903C5.57863 54.7786 2.20498 55.6587 1 53.3675" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
    </div>
  </div>
</section>

<script>
  function initReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  }

  initReveal();
  document.addEventListener('astro:after-swap', initReveal);
</script>