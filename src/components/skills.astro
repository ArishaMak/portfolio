---
import '../assets/styles/sections/skills.css';
import WordSearch from './WordSearch.astro';

const skillCategories = [
  {
    title: "Core Web Technologies",
    skills: [
      "HTML5", "CSS3", "Responsive Design (Flexbox, Grid)", "DOM Manipulation",
      "Web Accessibility (basic)", "Browser DevTools"
    ]
  },
  {
    title: "JavaScript & TypeScript",
    skills: [
      "JavaScript (ES6+)", "Asynchronous Programming (Promises, async/await)",
      "TypeScript (basic knowledge)", "OOP fundamentals",
      "Functional programming basics", "Modular architecture principles"
    ]
  },
  {
    title: "Frontend Frameworks & Libraries",
    skills: [
      "React", "React Hooks", "Component-based architecture",
      "React Router", "State lifting & component composition"
    ]
  },
  {
    title: "State Management",
    skills: ["Redux (basic knowledge)", "Redux Toolkit (basic)", "React Context API (basic)"]
  },
  {
    title: "API & Networking",
    skills: [
      "REST API integration", "RESTful API development",
      "HTTP methods & status codes", "JSON data handling"
    ]
  },
  {
    title: "Backend Fundamentals",
    skills: [
      "Node.js (basic level)", "Express.js",
      "Server routing basics", "Middleware concepts"
    ]
  },
  {
    title: "Databases",
    skills: [
      "SQL (DML, DDL)", "Database Design (Normalization, ER-modeling)",
      "MS SQL Server", "Data Integrity & Constraints",
      "Database Administration & Security"
    ]
  },
  {
    title: "Build Tools & Development Environment",
    skills: ["Vite", "npm / package management", "Project structure & configuration", "Environment variables"]
  },
  {
    title: "Testing & Debugging",
    skills: ["Jest (basic)", "Cypress (basic)", "AI-assisted Unit Testing", "Debugging tools", "Application optimization basics"]
  },
  {
    title: "AI & Prompt Engineering",
    skills: ["Prompt Engineering (CoT, Few-shot)", "LLM for Code Refactoring", "Workflow automation via AI", "AI-driven problem solving"]
  },
  {
    title: "Languages",
    skills: ["English – B1+", "Deutsch – A1+", "Russian – native", "Belarusian – native"]
  }
];
---

<section id="skills" class="section skills">
  <div class="skills__container">
   
    <div class="skills__header reveal">
      <div class="skills__title-wrapper">
         <h2 class="skills__title">Skills</h2>
         <svg class="skills__underline" width="248" height="144" viewBox="0 0 248 144" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M101.191 19.9936C102.537 9.65427 133.627 13.4701 141.343 14.2654C167.208 16.9314 187.665 24.711 209.222 35.3694C226.007 43.6685 243.729 59.5762 246.431 75.2661C250.212 97.2151 234.783 111.885 211.053 122.65C179.568 136.932 144.655 143 108.254 143C76.7356 143 43.4071 138.151 19.5797 121.343C-3.52079 105.048 -4.60965 82.4802 13.6943 63.2067C29.6912 46.3623 50.8072 33.012 74.6413 23.109C106.49 9.87591 144.86 5.86802 180.056 1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
         </svg>
      </div>
    </div>

    <!-- Word Search -->
    <WordSearch client:load />

    <!-- Карточки навыков -->
    <div class="skills__grid">
      {skillCategories.map((category, index) => (
        <div
          class="skill-card reveal"
          style={`--reveal-delay: ${index * 0.12}s`}
        >
          <video muted loop playsinline preload="none">
            <source src="/images/video-for-card.mp4" type="video/mp4">
          </video>
          <div class="skill-card__badge">
            <span>{category.title}</span>
          </div>
          <ul class="skill-card__list">
            {category.skills.map((skill) => (
              <li class="skill-card__item">{skill}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function initReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  }

  initReveal();
  document.addEventListener('astro:after-swap', initReveal);

  function initSkillsParallax() {
    const skillsSection = document.querySelector('.section.skills');
    if (!skillsSection) return;

    window.addEventListener('scroll', () => {
      const rect = skillsSection.getBoundingClientRect();
      const windowHeight = window.innerHeight;

      if (rect.top < windowHeight && rect.bottom > 0) {
        const scrollProgress = (windowHeight - rect.top) / (windowHeight + rect.height);
        const scale = 1 - (scrollProgress * 0.15);
        const translateZ = scrollProgress * -100;

        skillsSection.style.transform = `scale(${scale}) translateZ(${translateZ}px)`;
      }
    });
  }

  initSkillsParallax();
  document.addEventListener('astro:after-swap', initSkillsParallax);

  function initSkillVideos() {
    const cards = document.querySelectorAll('.skill-card');
    
    cards.forEach(card => {
      const video = card.querySelector('video');
      if (!video) return;

      // Запуск при hover
      card.addEventListener('mouseenter', () => {
        video.currentTime = 0; // с начала
        video.play().catch(e => console.log('Video play failed:', e));
      });

      // Пауза при уходе
      card.addEventListener('mouseleave', () => {
        video.pause();
        video.currentTime = 0;
      });
    });
  }

  // Инициализация
  initReveal();
  initSkillVideos();
  
  document.addEventListener('astro:after-swap', () => {
    initReveal();
    initSkillsParallax();
    initSkillVideos();
  });

  initSkillsParallax();
</script>