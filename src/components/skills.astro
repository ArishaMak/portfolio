---
import '../assets/styles/sections/skills.css';
import WordSearch from './WordSearch.astro';

const skillCategories = [
  {
    title: "Backend & APIs",
    skills: [
      "Node.js", "Express.js",
      "REST API design & auditing", "Middleware architecture",
      "JWT authentication", "AWS S3 (pre-signed URLs)",
      "Python (background workers)", "Docker (basic)"
    ]
  },
  {
    title: "Databases",
    skills: [
      "MongoDB (aggregate pipeline, Mongoose)",
      "MySQL · MS SQL Server",
      "SQL (DML, DDL)", "Database Design (3NF, ER-modeling)",
      "Triggers & Stored Procedures",
      "Indexes & Query Optimization"
    ]
  },
  {
    title: "JavaScript & TypeScript",
    skills: [
      "JavaScript (ES6+)", "async/await · Promises",
      "TypeScript", "OOP · Functional programming basics",
      "Modular architecture"
    ]
  },
  {
    title: "Frontend",
    skills: [
      "React 18 · Hooks", "Redux Toolkit · RTK",
      "Angular (NgZone, Directives)",
      "React Router v6", "Context API",
      "HTML5 · CSS3 · BEM · Flexbox · Grid"
    ]
  },
  {
    title: "Testing & Debugging",
    skills: [
      "Jest (unit tests, async mocks)",
      "Cypress (E2E, cy.intercept)",
      "Postman · Insomnia",
      "AI-assisted testing"
    ]
  },
  {
    title: "Build Tools & DevOps",
    skills: [
      "Vite · npm", "Git · Git Flow · GitLab MR",
      "Storybook", "ESLint · Prettier",
      "Environment config"
    ]
  },
  {
    title: "AI & Prompt Engineering",
    skills: [
      "Prompt Engineering (CoT, Few-shot)",
      "LLM for Code Refactoring",
      "Workflow automation via AI"
    ]
  },
  {
    title: "Languages",
    skills: [
      "English — B1+ (Intermediate+)",
      "Deutsch — A1+ (targeting B1)",
      "Russian — native",
      "Belarusian — native"
    ]
  }
];
---

<section id="skills" class="section skills">
  <div class="skills__container">

    <div class="skills__header reveal">
      <div class="skills__topbar">
        <span class="skills__label">Technical competencies</span>
        <span class="skills__count">{skillCategories.length} categories</span>
      </div>
      <div class="skills__rule"></div>
      <h2 class="skills__title">
        SKILLS <span class="skills__title-acc">&amp;</span> TOOLS
      </h2>
    </div>

    <div class="skills__ws-wrapper reveal">
      <div class="skills__ws-label">Find my skills — interactive wordsearch</div>
      <WordSearch client:load />
    </div>

    <div class="skills__grid">
      {skillCategories.map((category, index) => (
        <div class="skill-cat reveal" style={`--reveal-delay: ${index * 0.08}s`}>
          <div class="skill-cat__title">
            <span class="skill-cat__dash"></span>
            {category.title}
          </div>
          <ul class="skill-cat__list">
            {category.skills.map((skill) => (
              <li class="skill-cat__item">{skill}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="skills__bottom-rule"></div>
    <div class="skills__bottom-row">
      <span class="skills__bottom-note">
        Hover any category · Find words in the grid
      </span>
      <span class="skills__bottom-tag">Apr 2026 · BuzzyBooth US · Full-stack Intern</span>
    </div>

  </div>
</section>

<script>
  function initReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08 });
    document.querySelectorAll('.skills .reveal').forEach(el => observer.observe(el));
  }

  function init() {
    initReveal();
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>